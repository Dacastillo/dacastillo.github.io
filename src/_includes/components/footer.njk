<footer class="site-footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-brand">
        <span class="footer-name">{{ site.author.name }}</span>
        <p class="footer-tagline">{{ site.subtitle }}</p>
        <p class="footer-location">📍 {{ site.author.location }}</p>
      </div>
      
      <div class="footer-links">
        <h4 class="footer-heading">Quick Links</h4>
        <ul class="footer-nav">
          {% for item in navigation.main %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
          {% endfor %}
        </ul>
      </div>
      
      <div class="footer-social">
        <h4 class="footer-heading">Connect</h4>
        {% include "components/social-links.njk" %}
      </div>
    </div>
    
    <div class="footer-bottom">
      <p class="copyright">&copy; {{ site.author.name }} <span id="current-year"></span>. All rights reserved.</p>
      <p class="last-updated">Last updated: <span id="last-updated"></span></p>
      <p class="privacy-notice">Your privacy matters. This site uses no tracking cookies.</p>
    </div>
  </div>
</footer>
